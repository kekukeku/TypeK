{
  "$schema": "https://raw.githubusercontent.com/nicedoc/resources/main/tauri-conf-v2.json",
  "productName": "SayIt",
  "version": "0.1.0",
  "identifier": "com.sayit.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "SayIt",
        "width": 400,
        "height": 100,
        "x": null,
        "y": 0,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "resizable": false,
        "shadow": false
      },
      {
        "label": "main-window",
        "title": "SayIt - Dashboard",
        "url": "main-window.html",
        "width": 960,
        "height": 680,
        "visible": false,
        "decorations": true,
        "resizable": true,
        "center": true,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "SayIt"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.groq.com; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "signingIdentity": null
    }
  }
}
